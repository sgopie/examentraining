{% extends 'base.html.twig' %}

{% block body %}

    <div class="container py-5">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold mb-0">User Management</h2>
        </div>

        <!-- FILTERS -->
        <div class="card shadow-sm p-3 mb-4">
            <form method="get" class="row g-3">

                <!-- SEARCH -->
                <div class="col-md-6">
                    <input type="text"
                           name="search"
                           value="{{ app.request.get('search') }}"
                           class="form-control"
                           placeholder="Zoek op email...">
                </div>

                <!-- ROLE FILTER -->
                <div class="col-md-4">
                    <select name="role" class="form-select">
                        <option value="">Alle rollen</option>
                        <option value="ROLE_ADMIN" {{ app.request.get('role') == 'ROLE_ADMIN' ? 'selected' : '' }}>Admin</option>
                        <option value="ROLE_DOCENT" {{ app.request.get('role') == 'ROLE_DOCENT' ? 'selected' : '' }}>Docent</option>
                        <option value="ROLE_USER" {{ app.request.get('role') == 'ROLE_USER' ? 'selected' : '' }}>Gebruiker</option>
                    </select>
                </div>

                <div class="col-md-2 d-grid">
                    <button class="btn btn-primary">
                        Filter
                    </button>
                </div>

            </form>
        </div>

        <!-- TABLE -->
        <div class="card shadow-sm">

            <div class="table-responsive">
                <table class="table align-middle mb-0">

                    <thead class="table-light">
                    <tr>
                        <th>Email</th>
                        <th>Rollen</th>
                        <th class="text-end">Acties</th>
                    </tr>
                    </thead>

                    <tbody>

                    {% for user in users %}

                        <tr>
                            <td>{{ user.email }}</td>

                            <td>
                                {% for role in user.roles %}
                                    <span class="badge bg-secondary me-1">
                                    {{ role }}
                                </span>
                                {% endfor %}
                            </td>

                            <td class="text-end">

                                <!-- VIEW -->
                                <a href="{{ path('app_user_read', {user: user.id}) }}"
                                   class="btn btn-sm btn-outline-primary">
                                    Bekijken
                                </a>

                                <!-- EDIT -->
                                <a href="{{ path('app_user_edit', {user: user.id}) }}"
                                   class="btn btn-sm btn-outline-warning">
                                    Bewerken
                                </a>

                                <!-- DELETE BUTTON -->
                                <button class="btn btn-sm btn-outline-danger"
                                        data-bs-toggle="modal"
                                        data-bs-target="#deleteModal{{ user.id }}">
                                    Verwijderen
                                </button>

                            </td>
                        </tr>

                        <!-- DELETE MODAL -->
                        <div class="modal fade" id="deleteModal{{ user.id }}" tabindex="-1">
                            <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content">

                                    <div class="modal-header">
                                        <h5 class="modal-title">User verwijderen</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>

                                    <div class="modal-body">
                                        Weet je zeker dat je
                                        <strong>{{ user.email }}</strong>
                                        wilt verwijderen?
                                    </div>

                                    <div class="modal-footer">

                                        <button type="button"
                                                class="btn btn-secondary"
                                                data-bs-dismiss="modal">
                                            Annuleren
                                        </button>

                                        <form method="post"
                                              action="{{ path('app_user_delete', {user: user.id}) }}">
                                            <input type="hidden"
                                                   name="_token"
                                                   value="{{ csrf_token('delete_user_' ~ user.id) }}">

                                            <button class="btn btn-danger">
                                                Ja, verwijderen
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    {% else %}
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                Geen users gevonden
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
