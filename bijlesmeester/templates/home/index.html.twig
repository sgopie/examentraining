{% extends 'base.html.twig' %}

{% block body %}

    <div class="container py-5">

        <!-- HERO -->
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold">Bijlesmeester</h1>
            <p class="lead text-muted">
                Persoonlijke bijles, slimme planning en alles overzichtelijk op één plek.
            </p>

            {% if app.user %}
                <div class="mt-4">
                    <p class="text-muted mb-2">
                        Welkom, {{ app.user.userIdentifier }}
                    </p>
                    <a href="#" class="btn btn-success">
                        Ga naar dashboard
                    </a>
                </div>
            {% else %}
                <div class="mt-4">
                    <a href="{{ path('app_register') }}" class="btn btn-success me-2">
                        Schrijf je in
                    </a>
                    <a href="{{ path('app_login') }}" class="btn btn-outline-primary">
                        Login
                    </a>
                </div>
            {% endif %}
        </div>

        <!-- FEATURES -->
        <div class="row g-4">

            <div class="col-md-4">
                <div class="card shadow-sm h-100 p-3">
                    <h5 class="fw-bold">Voor leerlingen</h5>
                    <p class="text-muted small">
                        Bekijk je lessen, huiswerk en mededelingen. Beheer je planning en pas lessen eenvoudig aan.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100 p-3">
                    <h5 class="fw-bold">Voor docenten</h5>
                    <p class="text-muted small">
                        Plan lessen, houd overzicht en beheer leerlingen eenvoudig via je eigen dashboard.
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card shadow-sm h-100 p-3">
                    <h5 class="fw-bold">Shop</h5>
                    <p class="text-muted small">
                        Koop schoolproducten zoals usb-sticks, woordenboeken en meer.
                    </p>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
